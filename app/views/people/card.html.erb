<%
  first_membership = @person.first_membership
  latest_membership = @person.latest_membership
  member_since = first_membership&.start&.strftime("%B %Y") || "—"
  if latest_membership&.term_months.nil? && latest_membership.present?
    valid_through = "Lifetime"
  else
    valid_through = latest_membership&.end&.strftime("%B %Y") || "—"
  end
  active = latest_membership&.is_active?
  qr_svg = @qr.as_svg(
    module_size: 1, # Set to 1 since viewBox handles the scaling now
    standalone: true, # Changed to false if embedding directly into HTML
    use_path: true,
    viewbox: true
  ).sub(/<svg /, '<svg style="display:block; width:100%; height:100%;" ').html_safe
%>

<div class="membership-card" style="
  width: 680px;
  height: 428px;
  display: flex;
  flex-direction: column;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 8px 32px rgba(0,0,0,0.25);
  background: white;
  font-family: sans-serif;
">
  <!-- Header bar -->
  <div style="background: #1a2a4a; color: white; padding: 10px 18px; display: flex; align-items: center; gap: 12px; flex-shrink: 0;">
    <%= image_tag asset_path('logo_small.png'), style: 'width: 32px; height: 32px; object-fit: contain;', alt: 'SJAA' %>
    <div>
      <div style="font-size: 15px; font-weight: 700; letter-spacing: 0.04em;">San Jose Astronomical Association</div>
      <div style="font-size: 10px; letter-spacing: 0.12em; opacity: 0.75; text-transform: uppercase;">Membership Card</div>
    </div>
  </div>

  <!-- Card body -->
  <div style="flex: 1; display: flex; flex-direction: column; overflow: hidden;">

    <!-- Top row: name + member label -->
    <div style="padding: 12px 18px 10px 18px; flex-shrink: 0;">
      <div style="font-size: 48px; font-weight: 700; color: #1a2a4a; line-height: 1.1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
        <%= @person.first_name %> <%= @person.last_name %>
      </div>
      <div style="font-size: 13px; color: #6c757d; margin-top: 2px; letter-spacing: 0.04em;">
        Member
      </div>
    </div>

    <!-- Divider -->
    <div style="height: 1px; background: #e9ecef; margin: 0 18px; flex-shrink: 0;"></div>

    <!-- Bottom row: photo (left), member info (center), QR code (right) -->
    <div style="display: flex; flex: 1; gap: 18px; padding: 12px 18px; overflow: hidden;">

      <!-- Photo -->
      <div style="flex-shrink: 0;">
        <% if @person.profile_picture.attached? %>
          <%= image_tag @person.profile_picture.variant(:display),
                style: 'width: 160px; height: 100%; object-fit: cover; border-radius: 6px; border: 2px solid #ddd; display: block;',
                alt: @person.name %>
        <% else %>
          <div style="width: 160px; height: 100%; background: #e8edf5; border-radius: 6px; border: 2px solid #ddd; display: flex; align-items: center; justify-content: center; color: #8a9bbf;">
            <i class="bi bi-person-circle" style="font-size: 5rem;"></i>
          </div>
        <% end %>
      </div>

      <!-- Member info -->
      <div style="flex: 1; display: flex; flex-direction: column; justify-content: center; gap: 14px;">
        <div>
          <div style="font-size: 12px; color: #6c757d; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 2px;">Member Since</div>
          <div style="font-size: 20px; font-weight: 600; color: #1a2a4a;"><%= member_since %></div>
        </div>
        <div>
          <div style="font-size: 12px; color: #6c757d; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 2px;">Valid Through</div>
          <div style="font-size: 20px; font-weight: 600; color: #1a2a4a;"><%= valid_through %></div>
        </div>
        <div>
          <% if active %>
            <span style="background: #198754; color: white; font-size: 13px; font-weight: 600; padding: 4px 14px; border-radius: 20px; letter-spacing: 0.06em;">ACTIVE</span>
          <% else %>
            <span style="background: #dc3545; color: white; font-size: 13px; font-weight: 600; padding: 4px 14px; border-radius: 20px; letter-spacing: 0.06em;">EXPIRED</span>
          <% end %>
        </div>
      </div>

      <!-- QR code (big) -->
      <div style="flex-shrink: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 4px;">
        <div style="width: 200px; height: 200px; border: 1px solid #ddd; border-radius: 6px; padding: 6px; background: white;">
          <%= qr_svg %>
        </div>
        <div style="font-size: 9px; color: #adb5bd; letter-spacing: 0.04em;">ID: <%= @person.id %></div>
      </div>

    </div>
  </div>

  <!-- Footer stripe -->
  <div style="background: #1a2a4a; height: 6px; flex-shrink: 0;"></div>
</div>
